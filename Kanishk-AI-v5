/* ========== AI ENGINE CLASS ========== */
class AIEngine {
  constructor() {
    this.patterns = new Map();
    this.initializePatterns();
  }

  initializePatterns() {
    this.addPattern(/[\d+\-*/.()=]/i, this.solveMath.bind(this));
    this.addPattern(/(red|blue|green|yellow|purple|pink|orange|black|white|brown|color|rgb|hex)/i, this.handleColor.bind(this));
    this.addPattern(/(chess|cricket|football|basketball|tennis|badminton|game|rules|strategy)/i, this.handleGame.bind(this));
    this.addPattern(/(elon|shah|virat|taylor|cristiano|celebrity|actor|singer|player)/i, this.handleCelebrity.bind(this));
    this.addPattern(/(create|generate|make|draw|image|picture|design|artwork)/i, this.generateImage.bind(this));
    this.addPattern(/(script|youtube|video|tiktok|film|production|viral|content)/i, this.generateVideoScript.bind(this));
    this.addPattern(/(code|python|javascript|java|cpp|html|css|react|node|database|programming)/i, this.generateCode.bind(this));
    this.addPattern(/2625479242firstlove/, this.loveStory.bind(this));
    this.addPattern(/(kanishk|father|ranu|contact|address|village|bijnor)/i, this.kanishkInfo.bind(this));
  }

  addPattern(regex, handler) {
    this.patterns.set(regex, handler);
  }

  async process(message) {
    for (const [pattern, handler] of this.patterns) {
      if (pattern.test(message)) {
        return await handler(message);
      }
    }
    return this.generalResponse(message);
  }

  solveMath(msg) {
    try {
      const expr = msg.replace(/[^0-9+\-*/.()]/g, '');
      if (!expr) return this.mathHelp();
      const result = Function('"use strict"; return (' + expr + ')')();
      return `🔢 **Math Solution**\n\n**Expression:** ${expr}\n**Result:** ${result}\n\n✅ **Final Answer: ${result}**`;
    } catch(e) {
      return this.mathHelp();
    }
  }

  mathHelp() {
    return `🔢 **Math Help**\n\nExamples:\n✅ 15 + 25 = 40\n✅ 100 × 5 = 500\n✅ 120 ÷ 8 = 15\n✅ (50 + 30) × 2 - 10 = 150\n\nAsk any math question!`;
  }

  handleColor(msg) {
    for (const [colorName, colorData] of Object.entries(KNOWLEDGE_DB.colors)) {
      if (msg.toLowerCase().includes(colorName)) {
        return `🌈 **${colorName.toUpperCase()} Color**\n\n**HEX:** ${colorData.hex}\n**RGB:** ${colorData.rgb}\n**CMYK:** ${colorData.cmyk}\n**HSL:** ${colorData.hsl}\n\n**Psychology:** ${colorData.psychology}\n**Uses:** ${colorData.uses}\n**Variants:** ${colorData.variants.join(', ')}`;
      }
    }
    return `🌈 **Colors Available:** Red, Blue, Green, Yellow, Purple, Pink, Orange, Black, White, Brown`;
  }

  handleGame(msg) {
    for (const [gameName, gameData] of Object.entries(KNOWLEDGE_DB.games)) {
      if (msg.toLowerCase().includes(gameName)) {
        return `♟️ **${gameName.toUpperCase()} - Game Guide**\n\n**Description:** ${gameData.description}\n**Players:** ${gameData.players}\n**Origin:** ${gameData.origin}\n\n**Rules:** ${gameData.rules}\n**Difficulty:** ${gameData.difficulty}\n**Best for:** ${gameData.bestFor}`;
      }
    }
    return `♟️ **Games Available:** Chess, Cricket, Football, Basketball, Tennis, Badminton`;
  }

  handleCelebrity(msg) {
    for (const [celebName, celebData] of Object.entries(KNOWLEDGE_DB.celebrities)) {
      if (msg.toLowerCase().includes(celebName.split(' ')[0])) {
        return `⭐ **${celebName.toUpperCase()} - Information**\n\n**Age:** ${celebData.age}\n**Born:** ${celebData.born}\n\n**Career:** ${celebData.companies || celebData.films || celebData.sport}\n**Achievements:** ${celebData.achievements}\n**Net Worth:** ${celebData.net_worth}\n\n**Notable:** ${celebData.notable}`;
      }
    }
    return `⭐ **Celebrities:** Elon Musk, Shah Rukh Khan, Virat Kohli, Taylor Swift, Cristiano Ronaldo`;
  }

  generateImage(msg) {
    return `🎨 **Image Generated!**\n\nRequest: "${msg}"\n\n✅ Image created successfully\n✅ High quality\n✅ Ready to use`;
  }

  generateVideoScript(msg) {
    return `🎬 **Video Script**\n\n**[INTRO]** Hey everyone! Welcome!\n**[HOOK]** Stay till the end!\n**[MAIN]** Here's the content...\n**[CTA]** Like, Comment, Subscribe!\n**[OUTRO]** Thanks for watching!`;
  }

  generateCode(msg) {
    return `💻 **Python Code**\n\n\`\`\`python\nprint("Hello World")\nprint("Welcome to Kanishk AI")\n\`\`\`\n\n✅ Languages: Python, JavaScript, Java, C++, HTML, CSS`;
  }

  loveStory(msg) {
    return `💕 **Kanishk & Vanshika - Love Story**\n\n👨 Father loved Vanshika first\n💚 Kanishk fell in love on 26 October near Agri Dukaan\n💙 Vanshika loved Kanishk since class 5th\n\n❤️ **Two-Sided Love!**`;
  }

  kanishkInfo(msg) {
    return `👨‍👦 **Kanishk Information**\n\n**Name:** Kanishk\n**Father:** ${KANISHK_DB.father_name}}\n**Address:** ${KANISHK_DB.fullAddress}}\n\n**Contact:**\n📱 ${KANISHK_DB.father_contact[0]}}\n📱 ${KANISHK_DB.father_contact[1]}}\n📱 ${KANISHK_DB.father_contact[2]}}`;
  }

  generalResponse(msg) {
    return `🤖 **Kanishk AI Response**\n\nI can help with:\n✅ Math\n✅ Colors\n✅ Games\n✅ Celebrities\n✅ Code\n✅ Videos\n✅ Images\n✅ Kanishk Info\n✅ Love Story\n\nAsk anything!`;
  }
}

/* ========== GLOBAL APP INSTANCE ========== */
window.appInstance = {
  sessions: {},
  activeId: null,
  running: false,
  uname: localStorage.getItem('kai_name') || 'You',
  aiEngine: new AIEngine(),

  init() {
    console.log('✅ Kanishk AI Initialized');
    try {
      const saved = localStorage.getItem('kai_sessions');
      if (saved) this.sessions = JSON.parse(saved);
    } catch(e) {}
    
    document.getElementById('uav').textContent = this.uname[0].toUpperCase();
    document.getElementById('uname').textContent = this.uname;
    document.getElementById('name-inp').value = this.uname;
    
    this.renderHistory();
    this.attachEvents();
  },

  attachEvents() {
    const inp = document.getElementById('uinp');
    
    inp.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        this.send();
      }
    });

    inp.addEventListener('input', () => {
      const sendBtn = document.getElementById('sbtn');
      const hasText = inp.value.trim().length > 0;
      sendBtn.classList.toggle('rdy', hasText);
      sendBtn.disabled = !hasText;
    });
  },

  newChat() {
    this.activeId = null;
    document.getElementById('messages').innerHTML = '';
    document.getElementById('messages').style.display = 'none';
    document.getElementById('welcome').style.display = 'flex';
    document.getElementById('uinp').value = '';
    const sendBtn = document.getElementById('sbtn');
    sendBtn.classList.remove('rdy');
    sendBtn.disabled = true;
    this.renderHistory();
    this.toast('✨ New chat');
  },

  useSug(text) {
    const inp = document.getElementById('uinp');
    inp.value = text;
    const sendBtn = document.getElementById('sbtn');
    sendBtn.classList.add('rdy');
    sendBtn.disabled = false;
    inp.focus();
  },

  async send() {
    const inp = document.getElementById('uinp');
    const text = inp.value.trim();
    if (!text || this.running) return;

    document.getElementById('welcome').style.display = 'none';
    const mc = document.getElementById('messages');
    mc.style.display = 'block';

    if (!this.activeId) {
      this.activeId = this.genId();
      this.sessions[this.activeId] = {
        title: text.slice(0, 40),
        messages: []
      };
    }

    const sess = this.sessions[this.activeId];
    sess.messages.push({role: 'user', content: text});
    this.renderMsg('user', text);

    inp.value = '';
    document.getElementById('sbtn').classList.remove('rdy');
    document.getElementById('sbtn').disabled = true;
    this.saveSession();
    this.renderHistory();

    this.running = true;
    const aiRow = this.mkAIRow();
    await new Promise(r => setTimeout(r, 800));

    const response = await this.aiEngine.process(text);
    const te = aiRow.querySelector('.mt');
    te.innerHTML = this.renderMarkdown(response);
    
    this.scrollChat();
    sess.messages.push({role: 'assistant', content: response});
    this.saveSession();
    this.running = false;
  },

  renderMsg(role, text) {
    const mc = document.getElementById('messages');
    const row = document.createElement('div');
    row.className = 'mr' + (role === 'user' ? ' user' : '');

    const av = document.createElement('div');
    av.className = 'mav ' + (role === 'user' ? 'uav' : 'aav');
    av.textContent = role === 'user' ? (this.uname[0] || 'Y') : 'K';

    const body = document.createElement('div');
    body.className = 'mb';

    const lbl = document.createElement('div');
    lbl.className = 'mlbl';
    lbl.textContent = role === 'user' ? this.uname : 'Kanishk AI';

    const te = document.createElement('div');
    te.className = 'mt';
    te.innerHTML = role === 'user' ? this.esc(text) : this.renderMarkdown(text);

    body.appendChild(lbl);
    body.appendChild(te);

    if (role === 'user') {
      row.appendChild(body);
      row.appendChild(av);
    } else {
      row.appendChild(av);
      row.appendChild(body);
    }

    mc.appendChild(row);
    this.scrollChat();
  },

  mkAIRow() {
    const mc = document.getElementById('messages');
    const row = document.createElement('div');
    row.className = 'mr';

    const av = document.createElement('div');
    av.className = 'mav aav';
    av.textContent = 'K';

    const body = document.createElement('div');
    body.className = 'mb';

    const lbl = document.createElement('div');
    lbl.className = 'mlbl';
    lbl.textContent = 'Kanishk AI';

    const te = document.createElement('div');
    te.className = 'mt';
    te.innerHTML = '<div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>';

    body.appendChild(lbl);
    body.appendChild(te);
    row.appendChild(av);
    row.appendChild(body);
    mc.appendChild(row);
    this.scrollChat();
    return row;
  },

  renderMarkdown(text) {
    if (!text) return '';
    let html = this.esc(text);
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
    html = html.split('\n').join('<br>');
    return html;
  },

  esc(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  },

  scrollChat() {
    const area = document.getElementById('chat-area');
    area.scrollTop = area.scrollHeight;
  },

  genId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
  },

  saveSession() {
    try { localStorage.setItem('kai_sessions', JSON.stringify(this.sessions)); } catch(e) {}
  },

  renderHistory() {
    const list = document.getElementById('chat-list');
    const ids = Object.keys(this.sessions).sort((a, b) => b.localeCompare(a));
    
    list.innerHTML = '';
    ids.forEach(id => {
      const s = this.sessions[id];
      const btn = document.createElement('button');
      btn.className = 'chi' + (id === this.activeId ? ' active' : '');
      btn.innerHTML = `<span>${this.esc(s.title)}</span><span class="chi-dot"></span><button class="del" onclick="event.stopPropagation(); window.appInstance.deleteSession('${id}')">×</button>`;
      btn.onclick = () => this.loadSession(id);
      list.appendChild(btn);
    });
  },

  loadSession(id) {
    if (!this.sessions[id]) return;
    this.activeId = id;
    document.getElementById('welcome').style.display = 'none';
    const mc = document.getElementById('messages');
    mc.style.display = 'block';
    mc.innerHTML = '';
    this.sessions[id].messages.forEach(m => this.renderMsg(m.role, m.content));
    this.scrollChat();
    this.renderHistory();
  },

  deleteSession(id) {
    delete this.sessions[id];
    this.saveSession();
    if (this.activeId === id) this.newChat();
    else this.renderHistory();
    this.toast('💾 Chat deleted');
  },

  openSettings() {
    document.getElementById('sets-modal').classList.add('open');
    document.getElementById('name-inp').value = this.uname;
  },

  closeSets() {
    document.getElementById('sets-modal').classList.remove('open');
  },

  openSB() {
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sb-overlay').classList.add('show');
  },

  closeSB() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sb-overlay').classList.remove('show');
  },

  updateName(val) {
    if (!val.trim()) return;
    this.uname = val.trim();
    localStorage.setItem('kai_name', this.uname);
    document.getElementById('uav').textContent = this.uname[0].toUpperCase();
    document.getElementById('uname').textContent = this.uname;
    this.toast('✅ Name updated!');
  },

  clearAll() {
    if (!confirm('Delete ALL chats?')) return;
    this.sessions = {};
    this.saveSession();
    this.newChat();
    this.closeSets();
    this.toast('🗑️ All cleared');
  },

  toast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 3500);
  }
};

// Initialize
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => window.appInstance.init());
} else {
  window.appInstance.init();
}
</script>
